function getRisk(temp, humid) {
  if (temp < -45 && humid > 70) return 'HIGH';
  if (temp < -40 && humid > 40) return 'MEDIUM';
  return 'LOW';
}

function getSuggestion(f) {
  if (f.risk === 'HIGH') return `<span class="action">Action recommended.</span> ${f.callsign} is flying through conditions highly favourable for persistent contrail formation (${f.temp}°C / ${f.humid}% humidity). <strong>Descending 2,000–4,000ft</strong> would likely move this flight out of the ice-supersaturated layer and significantly reduce climate impact.`;
  if (f.risk === 'MEDIUM') return `Contrails are forming and may persist for minutes to hours. Conditions are borderline at ${f.humid}% humidity. <strong>Monitoring recommended.</strong> If humidity rises above 70%, an altitude adjustment would be beneficial.`;
  return `<span class="good">No action needed.</span> ${f.callsign} is flying through dry air at ${f.humid}% humidity. Contrails will dissolve almost immediately. <strong>This flight is operating with minimal contrail climate impact.</strong>`;
}

FLIGHTS.forEach(f => { f.risk = getRisk(f.temp, f.humid); });

let high = FLIGHTS.filter(f => f.risk==='HIGH').length;
let med = FLIGHTS.filter(f => f.risk==='MEDIUM').length;
let low = FLIGHTS.filter(f => f.risk==='LOW').length;

document.getElementById('h-total').textContent = FLIGHTS.length;
document.getElementById('h-high').textContent = high;
document.getElementById('h-low').textContent = low;
document.getElementById('map-high').textContent = high;
document.getElementById('map-med').textContent = med;
document.getElementById('map-low').textContent = low;

// MAP
const map = L.map('map', { center: [52.2, -1.2], zoom: 6 });
L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
  attribution: '© OpenStreetMap © CARTO', maxZoom: 18
}).addTo(map);

function riskColor(risk) {
  return { HIGH:'#c8341a', MEDIUM:'#c87a1a', LOW:'#1a7a3c' }[risk];
}

const markers = {};
FLIGHTS.forEach(f => {
  const col = riskColor(f.risk);
  const icon = L.divIcon({
    className: '',
    html: `<div style="width:12px;height:12px;border-radius:50%;background:${col};border:2px solid white;box-shadow:0 1px 4px rgba(0,0,0,0.3);cursor:pointer"></div>`,
    iconSize:[12,12], iconAnchor:[6,6]
  });
  markers[f.callsign] = L.marker([f.lat, f.lon], { icon })
    .addTo(map)
    .bindTooltip(`<b>${f.callsign}</b> · ${f.airline}<br>${(f.alt/1000).toFixed(1)}km · ${f.risk} RISK`, { direction:'top' })
    .on('click', () => showFlight(f));
});

function showFlight(f) {
  document.querySelectorAll('.fl-row').forEach(r => r.classList.remove('active'));
  const row = document.getElementById('row-'+f.callsign);
  if (row) { row.classList.add('active'); row.scrollIntoView({ block:'nearest' }); }

  document.getElementById('detailEmpty').style.display = 'none';
  document.getElementById('detailContent').classList.add('visible');

  const col = riskColor(f.risk);
  const bg = { HIGH:'var(--high-light)', MEDIUM:'var(--med-light)', LOW:'var(--low-light)' }[f.risk];

  document.getElementById('dc-callsign').textContent = f.callsign;
  document.getElementById('dc-airline').textContent = f.airline;
  document.getElementById('dc-risk-block').style.background = bg;
  document.getElementById('dc-risk-val').textContent = f.risk + ' RISK';
  document.getElementById('dc-risk-val').style.color = col;
  document.getElementById('dc-alt').textContent = (f.alt/1000).toFixed(1)+'km';
  document.getElementById('dc-temp').textContent = f.temp+'°C';
  document.getElementById('dc-humid').textContent = f.humid+'%';
  document.getElementById('dc-region').textContent = f.region === 'SOUTH' ? 'South UK' : 'North UK';
  document.getElementById('dc-suggestion').innerHTML = getSuggestion(f);
}

// FLIGHT LIST
let currentFilter = 'ALL';
function filterFlights(filter, el) {
  currentFilter = filter;
  document.querySelectorAll('.ftab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  renderList();
}

function renderList() {
  const container = document.getElementById('flightList');
  container.innerHTML = '';
  const filtered = FLIGHTS.filter(f => {
    if (currentFilter === 'ALL') return true;
    if (['HIGH','MEDIUM','LOW'].includes(currentFilter)) return f.risk === currentFilter;
    return f.region === currentFilter;
  }).sort((a,b) => b.alt - a.alt);

  const badgeClass = { HIGH:'rh', MEDIUM:'rm', LOW:'rl' };
  filtered.forEach(f => {
    const row = document.createElement('div');
    row.className = 'fl-row';
    row.id = 'row-'+f.callsign;
    row.innerHTML = `
      <div><div class="fl-callsign">${f.callsign}</div><div class="fl-airline">${f.airline}</div></div>
      <div class="fl-val">${(f.alt/1000).toFixed(1)}km</div>
      <div class="fl-val">${f.temp}°C</div>
      <div class="fl-val">${f.humid}%</div>
      <div><span class="risk-pill ${badgeClass[f.risk]}">${f.risk}</span></div>
    `;
    row.addEventListener('click', () => {
      showFlight(f);
      map.setView([f.lat, f.lon], 9);
      markers[f.callsign].openTooltip();
    });
    container.appendChild(row);
  });
}
renderList();
