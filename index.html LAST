  .leaflet-control-attribution { background:rgba(0,0,0,.35) !important; color:#8793a2 !important; }
  @media (max-width:1100px) { body { padding:14px; } .topbar, .grid { grid-template-columns:1fr; } .kpis { grid-template-columns:repeat(4, minmax(110px,1fr)); } .legend { grid-column:1/-1; border-left:0; padding-left:0; display:flex; } .table-top { grid-template-columns:1fr; } .search { padding:10px 14px; } }
  @media (max-width:760px) {
  body { padding:10px; }
  .topbar { gap:14px; }
  .brand { gap:12px; align-items:flex-start; }
  .brand-icon { width:48px; height:48px; }
  h1 { font-size:14px; line-height:1.2; }
  .subtitle { font-size:11px; margin-top:4px; }

  .kpis { grid-template-columns:repeat(2,1fr); gap:14px; width:100%; }
  .kpi { border:none; padding:0; min-height:auto; }
  .kpi-num { font-size:42px; }
  .kpi-label { font-size:12px; white-space:normal; }

  .legend {
    grid-column:span 2;
    border:none;
    padding:0;
    display:flex;
    justify-content:space-around;
    margin-top:8px;
  }

  .grid { grid-template-columns:1fr; gap:16px; }

  #map { height:320px; }

  .scale-card {
    width:calc(100% - 24px);
    left:12px;
    bottom:12px;
    padding:14px;
  }

  .detail { padding:16px; min-height:auto; }
  .callsign { font-size:26px; }

  .metrics, .insights, .details-grid { grid-template-columns:1fr; }
  .details-grid { gap:0; }

  .metric {
    border-left:none;
    border-top:1px solid var(--line-soft);
  }
  .metric:first-child { border-top:none; }

  .table-top { grid-template-columns:1fr; }

  .tabs {
    overflow-x:auto;
    padding:6px;
    gap:8px;
  }

  .tab {
    padding:10px 14px;
    white-space:nowrap;
  }

  .search { padding:12px; }

  .table-head { display:none; }

  .table-row {
    grid-template-columns:1fr auto;
    padding:14px;
    gap:12px;
  }

  .hide-sm { display:none; }
}
</style>
</head>
