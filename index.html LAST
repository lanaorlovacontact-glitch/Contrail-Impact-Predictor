function pseudoSpeed(f) { var seed = Array.from(f.callsign).reduce((a,c)=>a+c.charCodeAt(0),0); return 740 + (seed % 190); }
function pseudoTrack(f) { var n = Math.round(((f.lon + 6) * 37 + (f.lat - 49) * 51) % 360); return n < 0 ? n + 360 : n; }
FLIGHTS.forEach(function(f){ f.risk = getRisk(f.temp, f.humid); });
var high = FLIGHTS.filter(f=>f.risk==='HIGH').length, med = FLIGHTS.filter(f=>f.risk==='MEDIUM').length, low = FLIGHTS.filter(f=>f.risk==='LOW').length;
document.getElementById('totalCount').textContent = FLIGHTS.length; document.getElementById('tableTotal').textContent = FLIGHTS.length; document.getElementById('highCount').textContent = high; document.getElementById('medCount').textContent = med; document.getElementById('lowCount').textContent = low;
const map = L.map('map', { center:[52.25,-0.9], zoom:6, scrollWheelZoom:true });
L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', { attribution:'&copy; OpenStreetMap contributors', maxZoom:18 }).addTo(map);
const markers = {};
FLIGHTS.forEach(function(f){ var col = riskColor(f.risk); var icon = L.divIcon({ className:'', html:'<div style="width:14px;height:14px;border-radius:50%;background:'+col+';border:1px solid rgba(255,255,255,.72);box-shadow:0 0 12px '+col+'88"></div>', iconSize:[14,14], iconAnchor:[7,7] }); markers[f.callsign] = L.marker([f.lat, f.lon], { icon:icon }).addTo(map).bindTooltip('<b>'+f.callsign+'</b><br>'+f.airline+'<br>'+f.risk+' risk', { direction:'top' }).on('click', function(){ showFlight(f); }); });
function showFlight(f) { document.querySelectorAll('.table-row').forEach(r=>r.classList.remove('selected')); var row = document.getElementById('row-' + f.callsign); if (row) { row.classList.add('selected'); row.scrollIntoView({ block:'nearest' }); } var col = riskColor(f.risk); document.getElementById('selBody').innerHTML = '<div class="select-label">Selected flight</div><div class="flight-title"><div class="callsign">'+f.callsign+'</div><div class="risk-chip" style="color:'+col+'">'+f.risk+' risk</div></div><div class="airline">'+f.airline+'</div><div class="route">'+(f.region === 'SOUTH' ? 'South UK airspace' : 'North UK airspace')+' - live atmospheric sample</div><div class="metrics"><div class="metric"><div class="metric-label">Altitude</div><div class="metric-value">'+(f.alt/1000).toFixed(1)+'<sup style="font-size:13px"> km</sup></div><div class="metric-sub">'+altitudeBand(f.alt)+'</div></div><div class="metric"><div class="metric-label">Temperature</div><div class="metric-value">'+f.temp+' C</div></div><div class="metric"><div class="metric-label">Relative humidity</div><div class="metric-value">'+f.humid+'%</div></div><div class="metric"><div class="metric-label">Contrail potential</div><div class="metric-value" style="color:'+col+';font-family:var(--mono)">'+(f.risk.charAt(0)+f.risk.slice(1).toLowerCase())+'</div><div class="metric-sub">'+potentialText(f.risk)+'</div></div></div><div class="insights"><div class="insight"><div class="insight-icon">↯</div><div><div class="insight-title">Routing insight</div><div class="insight-copy">'+routingInsight(f)+'</div></div></div><div class="insight"><div class="insight-icon">☁</div><div><div class="insight-title">Environment</div><div class="insight-copy">'+(f.risk==='LOW'?'Low persistence conditions present':'Ice supersaturated conditions possible')+'</div></div></div></div><div class="flight-details"><div class="details-title">Flight details</div><div class="details-grid"><div><div class="detail-row"><span>Callsign</span><span>'+f.callsign+'</span></div><div class="detail-row"><span>Airline</span><span>'+f.airline+'</span></div><div class="detail-row"><span>Speed</span><span>'+pseudoSpeed(f)+' km/h</span></div><div class="detail-row"><span>Track</span><span>'+pseudoTrack(f)+' deg</span></div></div><div><div class="detail-row"><span>Latitude</span><span>'+f.lat.toFixed(4)+' N</span></div><div class="detail-row"><span>Longitude</span><span>'+Math.abs(f.lon).toFixed(4)+' '+(f.lon<0?'W':'E')+'</span></div><div class="detail-row"><span>Data source</span><span>ADS-B</span></div><div class="detail-row"><span>Region</span><span>'+f.region+'</span></div></div></div></div>'; }
var currentFilter = 'ALL';
function filterTable(filter, button) { currentFilter = filter; document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active')); button.classList.add('active'); renderTable(); }
function renderTable() { var q = (document.getElementById('searchBox').value || '').toLowerCase(); var rows = FLIGHTS.filter(function(f){ var filterOk = currentFilter === 'ALL' || f.risk === currentFilter; var textOk = !q || (f.callsign + ' ' + f.airline + ' ' + f.region).toLowerCase().includes(q); return filterOk && textOk; }).sort((a,b)=>b.alt-a.alt); var body = document.getElementById('tableRows'); body.innerHTML = ''; rows.forEach(function(f){ var row = document.createElement('div'); row.className = 'table-row'; row.id = 'row-' + f.callsign; row.innerHTML = '<span><strong>'+f.callsign+'</strong></span><span>'+f.airline+'</span><span class="hide-sm">'+(f.region==='SOUTH'?'South UK':'North UK')+'</span><span class="hide-sm">'+(f.alt/1000).toFixed(1)+' km</span><span class="hide-sm">'+f.temp+' C / '+f.humid+'%</span><span><span class="badge '+riskClass(f.risk)+'">'+f.risk+'</span></span>'; row.addEventListener('click', function(){ showFlight(f); map.setView([f.lat, f.lon], 9); markers[f.callsign].openTooltip(); }); body.appendChild(row); }); }
renderTable(); showFlight(FLIGHTS.find(f=>f.risk==='HIGH') || FLIGHTS[0]);
</script>
</body>
</html>
