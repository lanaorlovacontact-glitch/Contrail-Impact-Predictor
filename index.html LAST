  .brand-icon .trail { opacity:.78; }
  h1 { margin:0; font-family:var(--mono); font-size:22px; line-height:1; text-transform:uppercase; letter-spacing:.02em; }
  .subtitle { margin-top:10px; color:var(--muted); font-family:var(--mono); font-size:14px; }
  .kpis { display:grid; grid-template-columns:150px 126px 150px 126px 150px; gap:0; align-items:center; }
  .kpi { min-height:58px; padding:0 20px; border-left:1px solid var(--line); font-family:var(--mono); display:flex; flex-direction:column; justify-content:center; min-width:0; }
  .kpi:first-child { border-left:0; }
  .kpi-num { font-size:38px; line-height:.9; font-weight:800; color:var(--text); }
  .kpi-label { margin-top:11px; font-size:11px; line-height:1.05; color:var(--text); text-transform:uppercase; white-space:nowrap; }
  .legend { display:grid; gap:10px; padding-left:26px; border-left:1px solid var(--line); font-family:var(--mono); font-size:13px; }
  .legend span { display:flex; gap:12px; align-items:center; }
  .dot { width:10px; height:10px; border-radius:50%; display:inline-block; }
  .grid { display:grid; grid-template-columns:minmax(0, 1fr) minmax(420px, .9fr); gap:20px; min-width:0; }
  .panel { background:linear-gradient(180deg, rgba(16,23,32,.96), rgba(8,13,19,.96)); border:1px solid var(--line); border-radius:4px; box-shadow:0 28px 60px rgba(0,0,0,.3); overflow:hidden; min-width:0; }
  .panel-head { min-height:54px; padding:16px 18px; border-bottom:1px solid var(--line); display:flex; justify-content:space-between; align-items:center; font-family:var(--mono); text-transform:uppercase; color:var(--text); font-weight:700; }
  .pill { border:1px solid #3b4655; border-radius:20px; padding:6px 12px; color:var(--muted); font-size:12px; text-transform:none; font-weight:400; }
  #map { height:540px; background:#070b10; }
  .map-wrap { position:relative; }
  .scale-card { position:absolute; left:18px; bottom:20px; z-index:500; width:235px; padding:18px; border-radius:8px; background:rgba(16,23,32,.88); border:1px solid var(--line-soft); backdrop-filter:blur(10px); font-family:var(--mono); }
  .scale-title { font-size:13px; font-weight:700; margin-bottom:12px; }
  .scale { height:14px; border-radius:7px; background:linear-gradient(90deg, var(--green), var(--orange), var(--red)); }
  .scale-labels { margin-top:10px; display:flex; justify-content:space-between; font-size:12px; color:var(--text); }
  .detail { padding:22px; min-height:540px; min-width:0; overflow:hidden; }
  .select-label { color:#8da0b4; font-family:var(--mono); text-transform:uppercase; font-size:14px; margin-bottom:24px; }
  .flight-title { display:flex; gap:14px; align-items:center; flex-wrap:wrap; }
  .callsign { font-size:38px; line-height:1; font-weight:800; letter-spacing:-.02em; }
  .risk-chip { font-family:var(--mono); border:1px solid currentColor; border-radius:7px; padding:7px 12px; font-size:14px; font-weight:800; text-transform:uppercase; }
  .airline { margin-top:9px; color:var(--muted); font-family:var(--mono); font-size:15px; }
  .route { margin-top:10px; color:var(--text); font-family:var(--mono); font-size:15px; }
  .metrics { margin-top:22px; border:1px solid var(--line); border-radius:6px; display:grid; grid-template-columns:repeat(4, 1fr); overflow:hidden; }
  .metric { min-height:118px; padding:22px 18px; border-left:1px solid var(--line-soft); }
  .metric:first-child { border-left:0; }
  .metric-label { color:#8da0b4; font-family:var(--mono); text-transform:uppercase; font-size:12px; margin-bottom:16px; }
  .metric-value { font-size:28px; line-height:1; font-weight:800; }
  .metric-sub { margin-top:10px; color:var(--muted); font-family:var(--mono); font-size:13px; }
  .insights { margin-top:12px; display:grid; grid-template-columns:1.15fr .95fr; gap:12px; }
  .insight { min-height:96px; border:1px solid var(--line); border-radius:6px; padding:18px; display:grid; grid-template-columns:58px minmax(0,1fr); gap:16px; align-items:start; background:rgba(16,23,32,.72); }
  .insight-icon { width:46px; height:46px; border-radius:50%; display:grid; place-items:center; background:rgba(92,199,121,.12); color:var(--green); font-family:var(--mono); font-size:22px; }
  .insight-title { color:#8da0b4; font-family:var(--mono); text-transform:uppercase; font-size:12px; font-weight:800; margin:0 0 8px; }
  .insight-copy { color:var(--muted); font-family:var(--mono); font-size:14px; line-height:1.45; }
  .flight-details { margin-top:12px; border:1px solid var(--line); border-radius:6px; padding:18px; min-width:0; overflow:hidden; }
  .details-title { font-family:var(--mono); text-transform:uppercase; font-weight:800; margin-bottom:16px; }
  .details-grid { display:grid; grid-template-columns:minmax(0,1fr) minmax(0,1fr); gap:0 28px; min-width:0; }
  .detail-row { display:grid; grid-template-columns:minmax(86px, 34%) minmax(0, 1fr); gap:10px; padding:6px 0; font-family:var(--mono); font-size:14px; align-items:start; min-width:0; }
  .detail-row span { min-width:0; }
  .detail-row span:first-child { color:var(--text); }
  .detail-row span:last-child { color:var(--text); font-weight:700; overflow-wrap:break-word; text-align:left; }
  .empty { color:var(--muted); font-family:var(--mono); border:1px dashed var(--line); border-radius:6px; padding:42px; line-height:1.6; }
  .table-panel { margin-top:10px; }
  .table-top { min-height:52px; display:grid; grid-template-columns:220px 1fr 460px; align-items:center; border-bottom:1px solid var(--line); }
  .table-title { padding-left:18px; font-family:var(--mono); font-weight:800; text-transform:uppercase; }
  .tabs { display:flex; height:52px; align-items:stretch; }
  .tab { border:0; border-bottom:2px solid transparent; background:transparent; color:var(--muted); padding:0 25px; font-family:var(--mono); text-transform:uppercase; cursor:pointer; }
  .tab.active { color:var(--text); border-bottom-color:var(--cyan); }
  .search { padding:0 14px; }
  .search input { width:100%; height:36px; border:1px solid var(--line); border-radius:6px; background:#0a0f16; color:var(--text); padding:0 14px; font-family:var(--mono); outline:none; }
  .table-head, .table-row { display:grid; grid-template-columns:1fr 1.15fr .8fr .9fr .9fr .8fr; gap:18px; align-items:center; padding:0 36px; }
  .table-head { height:42px; color:#7f91a6; font-family:var(--mono); text-transform:uppercase; font-size:13px; border-bottom:1px solid var(--line); }
  .table-row { min-height:40px; border-bottom:1px solid var(--line-soft); color:var(--muted); font-family:var(--mono); font-size:14px; cursor:pointer; }
  .table-row:hover, .table-row.selected { background:#111923; }
  .table-row.selected { box-shadow:inset 3px 0 var(--cyan); }
  .table-row strong { color:var(--text); }
  .badge { display:inline-flex; justify-content:center; min-width:70px; border-radius:14px; padding:5px 10px; font-size:12px; font-weight:800; color:#fff; text-transform:uppercase; }
  .badge.high { background:linear-gradient(#ff735d,#b83f31); } .badge.medium { background:linear-gradient(#f4b038,#a56c16); } .badge.low { background:linear-gradient(#62c97b,#2c7d52); }
