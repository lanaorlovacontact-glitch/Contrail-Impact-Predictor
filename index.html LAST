<style>
  *, *::before, *::after { box-sizing: border-box; }
  :root {
    --bg:#070b10; --panel:#0b1017; --panel-2:#0f151e; --panel-3:#121923;
    --line:#26313f; --line-soft:#18212c; --text:#f2f5f8; --muted:#a9b5c4; --dim:#718093;
    --red:#ff6546; --orange:#f1a225; --green:#5cc779; --cyan:#5db7d8;
    --red-bg:#351614; --orange-bg:#33230d; --green-bg:#123021;
    --mono:Arial, Helvetica, sans-serif; --sans:Arial, Helvetica, sans-serif;
  }
  html, body { margin:0; min-height:100%; background:radial-gradient(circle at 20% 0%, #101824 0%, var(--bg) 42%); color:var(--text); font-family:var(--sans); }
  body { padding:22px; letter-spacing:0; }
  .app { max-width:1860px; margin:0 auto; }
  .topbar { display:grid; grid-template-columns:1fr auto; gap:24px; align-items:center; margin-bottom:18px; }
